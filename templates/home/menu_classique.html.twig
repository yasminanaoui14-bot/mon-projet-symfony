{% extends 'base.html.twig' %}

{% block body %}

<h1 class="mb-4">Menu Classique</h1>

<div class="card shadow">
    <div class="card-body">

        <h2>Menu Classique</h2>

        <img src="/images/menu-classique.jpg"
     class="img-fluid rounded mb-3"
     style="height:260px; object-fit:cover; width:100%;"
     alt="Menu Classique">

        <p>
            <strong>Description :</strong>
            Menu traditionnel français.
        </p>

        <p>🎉 Thème : Famille</p>

        <p><strong>⚠️ Allergènes :</strong> Gluten, œufs, lait, céleri</p>

        <p><strong>📋 Conditions :</strong></p>
<ul>
    <li>Commande minimum 20 personnes</li>
    <li>Réservation au moins 48h à l'avance</li>
    <li>Conservation entre 0°C et 4°C jusqu'au service</li>
</ul>

        <ul>
            <li>Entrée : Salade composée</li>
            <li>Plat : Poulet rôti et légumes</li>
            <li>Dessert : Tarte aux pommes</li>
        </ul>

<h3 class="mt-4">📸 Galerie du menu</h3>

<div class="row g-3 mt-2">
    <div class="col-md-4">
        <img src="/images/classique_salade_composee.jpg"
             class="img-fluid rounded shadow"
             alt="Salade composée">
    </div>

    <div class="col-md-4">
        <img src="/images/classique_poulet_legumes.jpg"
             class="img-fluid rounded shadow"
             alt="Poulet rôti aux légumes">
    </div>

    <div class="col-md-4">
        <img src="/images/classique_tarte_pomme.jpg"
             class="img-fluid rounded shadow"
             alt="Tarte aux pommes">
    </div>
</div>

        <p><strong>Minimum :</strong> 20 personnes</p>

        <h4 class="text-success">Prix : 39,90 €</h4>

        <a href="/commande?menu=1" class="btn btn-success">
            Commander
        </a>

        <a href="/menus" class="btn btn-secondary">
            Retour aux menus
        </a>

    </div>
</div>

{% endblock %}