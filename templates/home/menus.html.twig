{% extends 'base.html.twig' %}

{% block body %}

<h1 class="mb-4">Nos menus</h1>

<div class="card shadow mb-4">
    <div class="card-body">
        <h2 class="h4 mb-3">Rechercher un menu</h2>

        <form class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Prix maximum</label>
                <input type="number" class="form-control" placeholder="Ex : 150">
            </div>

            <div class="col-md-3">
                <label class="form-label">Fourchette de prix</label>
                <select class="form-select">
                    <option>Tous les prix</option>
                    <option>Moins de 100 €</option>
                    <option>100 € à 200 €</option>
                    <option>Plus de 200 €</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Thème</label>
<select class="form-select">
    <option>Tous</option>
    <option>Classique</option>
    <option>Festif</option>
    <option>Santé</option>
</select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Régime</label>
<select class="form-select">
    <option>Tous</option>
    <option>Végétarien</option>
</select>

            </div>

            <div class="col-md-2">
                <label class="form-label">Personnes min.</label>
                <input type="number" class="form-control" placeholder="Ex : 4">
            </div>

            <div class="col-12">
                <button type="button" class="btn btn-success">Filtrer</button>
                <button type="reset" class="btn btn-secondary">Réinitialiser</button>
            </div>
        </form>
    </div>
</div>

<input type="text"
       class="form-control mb-4"
       placeholder="Rechercher un menu...">

<div class="card shadow mb-4">
    <div class="card-body">

        <h2>Menu Classique</h2>

<span class="badge bg-primary mb-2">Classique</span>

<img src="/images/menu-classique.jpg"
     class="img-fluid rounded mb-3"
     style="height:260px; object-fit:cover; width:100%;"
     alt="Menu Classique">
<p>Menu traditionnel français</p>

<p>🎉 Thème : Classique</p>

<p>👥 Minimum : 4 personnes</p>

<p>💰 Prix : 80 €</p>

<a href="/menu-classique" class="btn btn-primary">Voir le détail</a>

<div class="card shadow mb-4">
    <div class="card-body">

       <h2>Menu Festif</h2>

<span class="badge bg-warning text-dark mb-2">Festif</span>

<img src="/images/menu-festif.jpg"
     class="img-fluid rounded mb-3"
     style="height:260px; object-fit:cover; width:100%;"
     alt="Menu Festif">

<p>Idéal pour les fêtes et événements</p>

        <p>🎉 Thème : Festif</p>

        <p>👥 Minimum : 10 personnes</p>

        <p>💰 Prix : 150 €</p>

      <a href="/menu-festif" class="btn btn-primary">Voir le détail</a>
</a>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">

        <h2>Menu Végétarien</h2>

<span class="badge bg-success mb-2">Végétarien</span>

<img src="/images/menu-vegetarien.jpg"
     class="img-fluid rounded mb-3"
     style="height:260px; object-fit:cover; width:100%;"
     alt="Menu Végétarien">

<p>Menu équilibré sans viande</p>

        <p>🎉 Thème : Santé</p>
        <p>🥗 Régime : Végétarien</p>
        <p>👥 Minimum : 6 personnes</p>
        <p>💰 Prix : 95 €</p>



        <a href="/menu-vegetarien" class="btn btn-primary">Voir le détail</a>
    </div>
</div>

{% endblock %}