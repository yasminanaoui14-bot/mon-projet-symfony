{% extends 'base.html.twig' %}

{% block body %}

<h1 class="mb-4">Nos menus</h1>

<div class="card shadow mb-4">
    <div class="card-body">
        <h2 class="h4 mb-3">Rechercher un menu</h2>

        <form method="get" action="{{ path('app_menus') }}" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Nombre de personnes</label>

                <input
                    type="number"
                    name="personnes"
                    class="form-control"
                    placeholder="Ex : 20"
                    value="{{ personnesSelectionnees }}">
            </div>

            <div class="col-md-3">
                <label class="form-label">Fourchette de prix</label>
                <select name="prix" class="form-select">
                    <option value="">Tous les prix</option>
                    <option value="moins_100">Moins de 100 €</option>
                    <option value="100_200">100 € à 200 €</option>
                    <option value="plus_200">Plus de 200 €</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Thème</label>
                <select name="theme" class="form-select">
    <option value="">Tous</option>

    <option value="Traditionnel"
        {% if themeSelectionne == 'Traditionnel' %}selected{% endif %}>
        Traditionnel
    </option>

    <option value="Festif"
        {% if themeSelectionne == 'Festif' %}selected{% endif %}>
        Festif
    </option>

    <option value="Végétarien"
        {% if themeSelectionne == 'Végétarien' %}selected{% endif %}>
        Végétarien
    </option>
</select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Régime</label>
<select name="regime" class="form-select">
    <option value="">Tous</option>
    <option value="vegetarien">Végétarien</option>
</select>

            </div>

            <div class="col-12">
               <button type="submit" class="btn btn-success">Filtrer</button>
                <button type="reset" class="btn btn-secondary">Réinitialiser</button>
            </div>
        </form>
    </div>
</div>


{% for menu in menus %}
<div class="card shadow mb-4">
    <div class="card-body">

        <h2>{{ menu.titre }}</h2>

        <span class="badge bg-primary mb-2">
            {{ menu.titre }}
        </span>

<img src="/images/{{ menu.image }}"
     class="img-fluid rounded mb-3"
     style="height:260px; object-fit:cover; width:100%;"
     alt="{{ menu.titre }}">

        <p>{{ menu.description }}</p>

        <p>🎉 Thème : {{ menu.theme }}</p>
        <p>👥 Minimum : {{ menu.nombre_personnes_min }} personnes</p>
        <p>💰 Prix : {{ menu.prix }} €</p>

        {% if menu.titre == 'Menu Classique' %}
    <a href="/menu-classique" class="btn btn-primary">Voir le détail</a>
{% elseif menu.titre == 'Menu Festif' %}
    <a href="/menu-festif" class="btn btn-primary">Voir le détail</a>
{% else %}
    <a href="/menu-vegetarien" class="btn btn-primary">Voir le détail</a>
{% endif %}
        

    </div>
</div>

{% endfor %}
{% endblock %}