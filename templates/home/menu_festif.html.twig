{% extends 'base.html.twig' %}

{% block body %}

<h1 class="mb-4">Menu Festif</h1>

<div class="card shadow">
    <div class="card-body">

        <h2>Menu Festif</h2>

        <img src="/images/menu-festif.jpg"
             class="img-fluid rounded mb-3"
             style="height:220px; object-fit:cover; width:100%;"
             alt="Menu Festif">

        <p>
            <strong>Description :</strong>
            Idéal pour les fêtes et événements.
        </p>

        <p>🎉 Thème : Festif</p>

        <ul>
            <li>Entrée : Foie gras</li>
            <li>Plat : Magret de canard</li>
            <li>Dessert : Bûche de Noël</li>
        </ul>

        <p><strong>Minimum :</strong> 10 personnes</p>

        <h4 class="text-success">Prix : 150 €</h4>

        <a href="/commande" class="btn btn-success">
            Commander
        </a>

        <a href="/menus" class="btn btn-secondary">
            Retour aux menus
        </a>

    </div>
</div>

{% endblock %}