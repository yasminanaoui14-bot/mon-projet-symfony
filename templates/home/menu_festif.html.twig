{% extends 'base.html.twig' %}

{% block body %}

<h1 class="mb-4">Menu Festif</h1>

<div class="card shadow">
    <div class="card-body">

        <h2>Menu Festif</h2>

        <img src="/images/menu-festif.jpg"
             class="img-fluid rounded mb-3"
             style="height:220px; object-fit:cover; width:100%;"
             alt="Menu Festif">

        <p>
            <strong>Description :</strong>
            Idéal pour les fêtes et événements.
        </p>

        <p>🎉 Thème : Festif</p>
        
        <p><strong>⚠️ Allergènes :</strong> Gluten, œufs, lait, fruits de mer, sulfites</p>

        <p><strong>📋 Conditions :</strong></p>
<ul>
        <li>Commande minimum 30 personnes</li>
        <li>Réservation au moins 7 jours à l'avance</li>
        <li>Menu adapté aux mariages, anniversaires et événements professionnels</li>
        <li>Conservation au frais jusqu'au service</li>
</ul>

        <ul>
            <li>Entrée : Foie gras</li>
            <li>Plat : Magret de canard</li>
            <li>Dessert : Bûche de Noël</li>
        </ul>

<h3 class="mt-4">📸 Galerie du menu</h3>

<div class="row g-3 mt-2">
    <div class="col-md-4">
        <img src="/images/foie_grasMF.jpg" class="img-fluid rounded shadow" alt="Foie gras">
    </div>

    <div class="col-md-4">
        <img src="/images/magret_canardMF.jpg" class="img-fluid rounded shadow" alt="Magret de canard">
    </div>

    <div class="col-md-4">
        <img src="/images/buche_noelMF.jpg" class="img-fluid rounded shadow" alt="Bûche de Noël">
    </div>
</div>

        <p><strong>Minimum :</strong> 30 personnes</p>

        <h4 class="text-success">Prix : 59,90 €</h4>

        <a href="/commande?menu=2" class="btn btn-success">
            Commander
        </a>

        <a href="/menus" class="btn btn-secondary">
            Retour aux menus
        </a>

    </div>
</div>

{% endblock %}