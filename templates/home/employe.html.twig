{% extends 'base.html.twig' %}

{% block body %}

<h1 class="mb-4">👨‍💼 Espace Employé</h1>

<div class="card shadow mb-4">
    <div class="card-body">
        <h2>Gestion des commandes</h2>

        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Commande</th>
                    <th>Client</th>
                    <th>Menu</th>
                    <th>Date</th>
                    <th>Statut</th>
                </tr>
            </thead>

            <tbody>
<div class="card shadow mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">🔎 Rechercher une commande</h2>

        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label for="client" class="form-label">Client</label>
                <input
                    type="text"
                    id="client"
                    name="client"
                    class="form-control"
                    value="{{ app.request.query.get('client') }}"
                    placeholder="Nom ou adresse e-mail"
                >
            </div>

            <div class="col-md-5">
                <label for="filtre-statut" class="form-label">Statut</label>

                <select
                    id="filtre-statut"
                    name="statut"
                    class="form-select"
                >
                    <option value="">Tous les statuts</option>
                    <option value="En attente">En attente</option>
                    <option value="Acceptée">Acceptée</option>
                    <option value="Refusée">Refusée</option>
                    <option value="En préparation">En préparation</option>
                    <option value="En cours de livraison">En cours de livraison</option>
                    <option value="Livrée">Livrée</option>
                    <option value="En attente du retour de matériel">
                        En attente du retour de matériel
                    </option>
                    <option value="Terminée">Terminée</option>
                    <option value="Annulée">Annulée</option>
                </select>
            </div>

            <div class="d-flex gap-2">
    <button type="submit" class="btn btn-success">
        Rechercher
    </button>

    <a href="{{ path('app_employe') }}" class="btn btn-secondary">
        Réinitialiser
    </a>
</div>
            </div>
        </form>
    </div>
</div>

                {% for id, commande in commandes %}
                    <tr>
                        <td>#{{ commande.id }}</td>
                        <td>{{ commande.nom_client }}<br><small>{{ commande.email_client }}</small></td>
                        <td>{{ commande.menu }}</td>
                        <td>{{ commande.date_prestation }}</td>
                        <td>
                            <span class="badge bg-primary">{{ commande.statut }}</span>
                        </td>
                
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucune commande trouvée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow mb-4 mt-4">
    <div class="card-body">
        <h2>Annulation d'une commande</h2>

        <p>
            Avant d'annuler une commande, l'employé doit contacter le client par appel, SMS ou email.
        </p>

        <form>
            <div class="mb-3">
                <label class="form-label">Commande concernée</label>
                <select class="form-select">
                    <option>#001 - Yasmina Nao</option>
                    <option>#002 - Florian Clau</option>
                    <option>#003 - Riad Inao</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Mode de contact utilisé</label>
                <select class="form-select">
                    <option>Appel téléphonique</option>
                    <option>SMS</option>
                    <option>Email</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Motif d'annulation</label>
                <textarea class="form-control" rows="3" placeholder="Motif de l'annulation"></textarea>
            </div>

            <button class="btn btn-danger">Annuler la commande</button>
        </form>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        
<div class="card shadow mb-4">
    <div class="card-body">
        <h2>⭐ Gestion des avis</h2>

        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Client</th>
                    <th>Note</th>
                    <th>Commentaire</th>
                    <th>Statut</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                {% for avisItem in avis %}
            <tr>
    <td>{{ avisItem.client }}</td>
    <td>{{ avisItem.note }}/5</td>
    <td>{{ avisItem.commentaire }}</td>
    <td>{{ avisItem.statut }}</td>
    <td>
        <form method="post">
            <input type="hidden" name="action" value="avis">
            <input type="hidden" name="avis_id" value="{{ avisItem.id }}">

            <select name="decision" class="form-select form-select-sm">
                <option value="Validé">Valider</option>
                <option value="Refusé">Refuser</option>
            </select>

            <button class="btn btn-primary btn-sm mt-1">
                OK
            </button>
        </form>
    </td>
</tr>
{% endfor %}

