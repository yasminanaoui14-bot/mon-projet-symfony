<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">

    <title>Vite & Gourmand</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #ffffff;
    color: #1f2937;
}

.site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 25px 45px;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    gap: 20px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 15px;
}

.logo-icon {
    font-size: 45px;
}

.logo h2 {
    margin: 0;
    font-size: 28px;
    color: #198754;
    font-weight: bold;
}

.logo p {
    margin: 0;
    font-size: 13px;
    color: #666;
}

.nav-buttons,
.admin-buttons {
    display: flex;
    gap: 12px;
    align-items: center;
}

.nav-buttons .btn,
.admin-buttons .btn {
    padding: 12px 20px;
    font-weight: bold;
    border-radius: 8px;
}

main {
    min-height: 500px;
}

.hero {
    background-image: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)),
    url('https://images.unsplash.com/photo-1555244162-803834f70033?auto=format&fit=crop&w=1600&q=80');
    background-size: cover;
    background-position: center;
    padding: 60px 45px;
}

.hero-card {
    background: rgba(255,255,255,0.92);
    padding: 45px;
    border-radius: 18px;
    max-width: 650px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.2);
}

.hero-card h1 {
    font-size: 50px;
    font-weight: bold;
    margin-bottom: 20px;
}

.hero-card span {
    color: #198754;
}

.hero-card p {
    font-size: 22px;
    margin-bottom: 25px;
}

.hero-card p {
    font-size: 22px;
    margin-bottom: 25px;
}

main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 30px 20px;
}

img {
    max-width: 100%;
}

.card img {
    height: 260px;
    object-fit: cover;
    width: 100%;
}

form {
    max-width: 850px;
}

.form-control,
.form-select {
    max-width: 100%;
}

.footer {
    background: #f8f9fa;
    text-align: center;
    padding: 30px;
    margin-top: 50px;
}

.section-info {
    padding: 40px 55px;
}

.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 35px;
    margin-bottom: 35px;
}

.info-box {
    background: #ffffff;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 3px 12px rgba(0,0,0,0.08);
}

.info-box h2 {
    color: #198754;
}

.avis-box {
    background: white;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 3px 12px rgba(0,0,0,0.08);
}

.avis-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
}

.avis-card {
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 25px;
    background: #fff;
}

.stars {
    color: #ffc107;
    font-size: 22px;
}

.footer {
    background: #f8f9fa;
    text-align: center;
    padding: 30px;
    margin-top: 40px;
}

.footer h3 {
    font-weight: bold;
}

@media (max-width: 900px) {
    .site-header {
        flex-direction: column;
    }

    .info-grid,
    .avis-grid {
        grid-template-columns: 1fr;
    }

    .hero-card h1 {
        font-size: 36px;
    }
}
</style>

</head>
<body>
<div class="container-fluid p-0">

    <header class="site-header">
        <div class="logo">
            <div class="logo-icon">🍽️</div>
            <div>
                <h2>Vite & Gourmand</h2>
                <p>Des menus gourmands pour tous vos événements</p>
            </div>
        </div>

        <nav class="nav-buttons">
            <a href="/" class="btn btn-primary">🏠 Accueil</a>
            <a href="/menus" class="btn btn-success">📖 Menus</a>
            <a href="/contact" class="btn btn-info">✉️ Contact</a>
            {% if app.session.get('user_id') %}


        <a href="/mon-compte" class="btn btn-secondary">👤 Mon compte</a>

    {% if app.session.get('role') == 'ROLE_ADMIN' %}
        <a href="/admin" class="btn btn-dark">⚙️ Admin</a>
        <a href="/rapport" class="btn btn-secondary">📊 Rapport</a>
    {% endif %}

    {% if app.session.get('role') == 'ROLE_EMPLOYE' or app.session.get('role') == 'employe' %}
        <a href="/employe" class="btn btn-dark">👨‍🍳 Employé</a>
    {% endif %}



    <a href="/logout" class="btn btn-outline-danger">Déconnexion</a>

{% else %}

    <a href="/login" class="btn btn-warning">🔐 Connexion</a>
    <a href="/register" class="btn btn-danger">👥 Inscription</a>

{% endif %}


        </nav>
    </header>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="footer">
        <h3>🍽️ Vite & Gourmand</h3>
        <p>Horaires : Lundi au Dimanche - De 11h00 à 14h30 et de 18h30 à 23h30</p>
        <a href="#">Mentions légales</a> |
        <a href="#">CGV</a>
    </footer>

</div>
</body>
</html>