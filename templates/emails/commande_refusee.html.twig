<div style="background:#f4f6f5;padding:30px;font-family:Arial,sans-serif;">
    <div style="max-width:600px;margin:auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 14px rgba(0,0,0,0.08);">

        <div style="background:#dc3545;color:#ffffff;padding:24px;text-align:center;">
            <h1 style="margin:0;">🍽️ Vite & Gourmand</h1>
            <p style="margin:8px 0 0;">Commande non acceptée</p>
        </div>

        <div style="padding:30px;color:#222222;">
            <h2 style="color:#dc3545;">Bonjour {{ nom }},</h2>

            <p>
                Nous sommes désolés, votre commande n’a pas pu être acceptée.
            </p>

            <div style="background:#f8f9fa;border-left:4px solid #dc3545;padding:16px;margin:24px 0;">
                <p><strong>Date demandée :</strong> {{ date }}</p>
                <p><strong>Heure :</strong> {{ heure }}</p>
                <p><strong>Nombre de personnes :</strong> {{ personnes }}</p>
            </div>

            {% if motif is defined and motif %}
                <p><strong>Motif :</strong> {{ motif }}</p>
            {% endif %}

            <p>
                Vous pouvez nous contacter ou effectuer une nouvelle demande avec une autre date.
            </p>

            <div style="text-align:center;margin:30px 0;">
                <a href="http://localhost:8000/contact"
                   style="background:#dc3545;color:#ffffff;text-decoration:none;padding:12px 24px;border-radius:8px;display:inline-block;">
                    Nous contacter
                </a>
            </div>

            <p style="margin-bottom:0;">
                Cordialement,<br>
                <strong>L'équipe Vite & Gourmand</strong>
            </p>
        </div>

        <div style="background:#f1f1f1;padding:14px;text-align:center;font-size:12px;color:#666666;">
            Vite & Gourmand — Service client
        </div>

    </div>
</div>